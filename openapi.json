          },
          "name": {
            "type": "string",
            "description": "Name of the tool to call"
          }
        }
      },
      "ToolDefinition": {
        "type": "object",
        "description": "Definition of a tool that an agent can use.",
        "required": [
          "name",
          "description",
          "parameters_schema"
        ],
        "properties": {
          "description": {
            "type": "string",
            "description": "Human-readable description of what the tool does"
          },
          "name": {
            "type": "string",
            "description": "Unique name of the tool"
          },
          "parameters_schema": {
            "description": "JSON Schema for the tool's parameters"
          }
        }
      },
      "ToolResult": {
        "type": "object",
        "description": "The result of a tool execution.",
        "required": [
          "tool_call_id",
          "content"
        ],
        "properties": {
          "content": {
            "type": "string",
