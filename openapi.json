{
  "openapi": "3.1.0",
  "info": {
    "title": "Portal Bridge API",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/agents": {
      "get": {
        "tags": [
          "crate::handlers::agents"
        ],
        "summary": "GET /agents — list all loaded agents.",
        "operationId": "list_agents",
        "responses": {
          "200": {
            "description": "List of agent summaries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/agents/{agent_id}": {
      "get": {
        "tags": [
          "crate::handlers::agents"
        ],
        "summary": "GET /agents/:agent_id — get agent details.",
        "operationId": "get_agent",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent details",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Agent not found"
          }
        }
      }
    },
    "/agents/{agent_id}/conversations": {
      "post": {
        "tags": [
          "crate::handlers::conversations"
        ],
        "summary": "POST /agents/:agent_id/conversations — create a new conversation.",
        "operationId": "create_conversation",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Conversation created",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Agent not found"
          }
        }
      }
    },
    "/agents/{agent_id}/conversations/{conv_id}/approvals": {
      "get": {
        "tags": [
          "crate::handlers::permissions"
        ],
        "summary": "List all pending approval requests for a conversation.",
        "operationId": "list_approvals",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "conv_id",
            "in": "path",
            "description": "Conversation identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of pending approvals",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ApprovalRequest"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "crate::handlers::permissions"
        ],
        "summary": "Bulk resolve multiple pending approval requests.",
        "operationId": "bulk_resolve_approvals",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "conv_id",
            "in": "path",
            "description": "Conversation identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BulkApprovalReply"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Bulk approval result",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/agents/{agent_id}/conversations/{conv_id}/approvals/{request_id}": {
      "post": {
        "tags": [
          "crate::handlers::permissions"
        ],
        "summary": "Resolve a single pending approval request.",
        "operationId": "resolve_approval",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "conv_id",
            "in": "path",
            "description": "Conversation identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "request_id",
            "in": "path",
            "description": "Approval request identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApprovalReply"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Approval resolved",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Approval request not found"
          }
        }
      }
    },
    "/conversations/{conv_id}": {
      "delete": {
        "tags": [
          "crate::handlers::conversations"
        ],
        "summary": "DELETE /conversations/:conv_id — end a conversation.",
        "operationId": "end_conversation",
        "parameters": [
          {
            "name": "conv_id",
            "in": "path",
            "description": "Conversation identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Conversation ended",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Conversation not found"
          }
        }
      }
    },
    "/conversations/{conv_id}/abort": {
      "post": {
        "tags": [
          "crate::handlers::conversations"
        ],
        "summary": "POST /conversations/:conv_id/abort — abort the current in-flight turn.",
        "operationId": "abort_conversation",
        "parameters": [
          {
            "name": "conv_id",
            "in": "path",
            "description": "Conversation identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Turn aborted",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Conversation not found"
          }
        }
      }
    },
    "/conversations/{conv_id}/messages": {
      "post": {
        "tags": [
          "crate::handlers::conversations"
        ],
        "summary": "POST /conversations/:conv_id/messages — send a message to a conversation.",
        "operationId": "send_message",
        "parameters": [
          {
            "name": "conv_id",
            "in": "path",
            "description": "Conversation identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendMessageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Message accepted",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "404": {
            "description": "Conversation not found"
          }
        }
      }
    },
    "/conversations/{conv_id}/stream": {
      "get": {
        "tags": [
          "crate::handlers::stream"
        ],
        "summary": "GET /conversations/:conv_id/stream — SSE stream for a conversation.",
        "operationId": "stream_conversation",
        "parameters": [
          {
            "name": "conv_id",
            "in": "path",
            "description": "Conversation identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "SSE event stream",
            "content": {
              "text/event-stream": {}
            }
          },
          "404": {
            "description": "Conversation not found"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "crate::handlers::health"
        ],
        "summary": "GET /health — health check endpoint.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Health check",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/metrics": {
      "get": {
        "tags": [
          "crate::handlers::metrics"
        ],
        "summary": "GET /metrics — collect and return metrics from all agents.",
        "operationId": "get_metrics",
        "responses": {
          "200": {
            "description": "Metrics snapshot",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MetricsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/push/agents": {
      "post": {
        "tags": [
          "crate::handlers::push"
        ],
        "summary": "POST /push/agents — bulk seed agents.",
        "operationId": "push_agents",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushAgentsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Agents loaded",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/push/agents/{agent_id}": {
      "put": {
        "tags": [
          "crate::handlers::push"
        ],
        "summary": "PUT /push/agents/{agent_id} — add if new, update if version differs, no-op if same version.",
        "operationId": "upsert_agent",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentDefinition"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Agent unchanged or updated",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "201": {
            "description": "Agent created",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "400": {
            "description": "Invalid request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      },
      "delete": {
        "tags": [
          "crate::handlers::push"
        ],
        "summary": "DELETE /push/agents/{agent_id} — remove an agent.",
        "operationId": "remove_agent",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Agent removed",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Agent not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/push/agents/{agent_id}/conversations": {
      "post": {
        "tags": [
          "crate::handlers::push"
        ],
        "summary": "POST /push/agents/{agent_id}/conversations — hydrate conversations for an agent.",
        "operationId": "hydrate_conversations",
        "parameters": [
          {
            "name": "agent_id",
            "in": "path",
            "description": "Agent identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/HydrateConversationsRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Conversations hydrated",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "404": {
            "description": "Agent not found"
          },
          "409": {
            "description": "Agent has active conversations"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    },
    "/push/diff": {
      "post": {
        "tags": [
          "crate::handlers::push"
        ],
        "summary": "POST /push/diff — apply a diff of agent changes.",
        "operationId": "push_diff",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PushDiffRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Diff applied",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "AgentConfig": {
        "type": "object",
        "description": "Configuration options for an agent.",
        "properties": {
          "compaction": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/CompactionConfig",
                "description": "Conversation compaction configuration"
              }
            ]
          },
          "json_schema": {
            "description": "JSON schema for structured output"
          },
          "max_tokens": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "description": "Maximum tokens for LLM response",
            "minimum": 0
          },
          "max_turns": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "description": "Maximum conversation turns",
            "minimum": 0
          },
          "rate_limit_rpm": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "description": "Rate limit in requests per minute",
            "minimum": 0
          },
          "temperature": {
            "type": [
              "number",
              "null"
            ],
            "format": "double",
            "description": "Temperature for LLM sampling"
          }
        }
      },
      "AgentDefinition": {
        "type": "object",
        "description": "Complete definition of an AI agent fetched from the control plane.",
        "required": [
          "id",
          "name",
          "system_prompt",
          "provider"
        ],
        "properties": {
          "config": {
            "$ref": "#/components/schemas/AgentConfig",
            "description": "Agent configuration options"
          },
          "description": {
            "type": [
              "string",
              "null"
            ],
            "description": "Human-readable description of the agent's purpose and capabilities.\nUsed in tool documentation when this agent is a subagent."
          },
          "id": {
            "$ref": "#/components/schemas/String",
            "description": "Unique agent identifier"
          },
          "integrations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IntegrationDefinition"
            },
            "description": "External integrations (e.g., GitHub, Slack, Mailchimp).\nEach integration's actions become individual tools for the agent."
          },
          "mcp_servers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/McpServerDefinition"
            },
            "description": "MCP server connections"
          },
          "name": {
            "type": "string",
            "description": "Human-readable agent name"
          },
          "permissions": {
            "type": "object",
            "description": "Per-tool permission overrides. Key = tool name, Value = permission level.\nTools not listed default to `Allow`.",
            "additionalProperties": {
              "$ref": "#/components/schemas/ToolPermission"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "provider": {
            "$ref": "#/components/schemas/ProviderConfig",
            "description": "LLM provider configuration"
          },
          "skills": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SkillDefinition"
            },
            "description": "Available skills"
          },
          "subagents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AgentDefinition"
            },
            "description": "Nested subagent definitions"
          },
          "system_prompt": {
            "type": "string",
            "description": "System prompt for the agent"
          },
          "tools": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ToolDefinition"
            },
            "description": "Agent-defined tools"
          },
          "updated_at": {
            "type": [
              "string",
              "null"
            ],
            "description": "Last updated timestamp for change detection"
          },
          "version": {
            "type": [
              "string",
              "null"
            ],
            "description": "Version field for change detection during sync"
          },
          "webhook_secret": {
            "type": [
              "string",
              "null"
            ],
            "description": "Webhook secret for HMAC signing"
          },
          "webhook_url": {
            "type": [
              "string",
              "null"
            ],
            "description": "Webhook URL for event delivery"
          }
        }
      },
      "AgentSummary": {
        "type": "object",
        "description": "Lightweight agent summary for listing endpoints.",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "$ref": "#/components/schemas/String",
            "description": "Agent identifier"
          },
          "name": {
            "type": "string",
            "description": "Agent name"
          },
          "version": {
            "type": [
              "string",
              "null"
            ],
            "description": "Agent version"
          }
        }
      },
      "ApprovalDecision": {
        "type": "string",
        "description": "The user's decision on an approval request.",
        "enum": [
          "approve",
          "deny"
        ]
      },
      "ApprovalReply": {
        "type": "object",
        "description": "HTTP request body for resolving a single approval.",
        "required": [
          "decision"
        ],
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/ApprovalDecision"
          }
        }
      },
      "ApprovalRequest": {
        "type": "object",
        "description": "A pending approval request for a tool call.",
        "required": [
          "id",
          "agent_id",
          "conversation_id",
          "tool_name",
          "tool_call_id",
          "arguments",
          "status",
          "created_at"
        ],
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Agent that initiated the tool call."
          },
          "arguments": {
            "description": "Arguments passed to the tool."
          },
          "conversation_id": {
            "type": "string",
            "description": "Conversation in which the tool call occurred."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the approval request was created."
          },
          "id": {
            "type": "string",
            "description": "Unique ID for this approval request."
          },
          "status": {
            "$ref": "#/components/schemas/ApprovalStatus",
            "description": "Current status of the approval request."
          },
          "tool_call_id": {
            "type": "string",
            "description": "The LLM's tool call ID."
          },
          "tool_name": {
            "type": "string",
            "description": "Name of the tool being called."
          }
        }
      },
      "ApprovalStatus": {
        "type": "string",
        "description": "Status of an approval request.",
        "enum": [
          "pending",
          "approved",
          "denied"
        ]
      },
      "BulkApprovalReply": {
        "type": "object",
        "description": "HTTP request body for resolving multiple approvals at once.",
        "required": [
          "request_ids",
          "decision"
        ],
        "properties": {
          "decision": {
            "$ref": "#/components/schemas/ApprovalDecision"
          },
          "request_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CompactionConfig": {
        "type": "object",
        "description": "Configuration for conversation compaction (history summarization).",
        "required": [
          "summary_provider"
        ],
        "properties": {
          "summary_prompt": {
            "type": [
              "string",
              "null"
            ],
            "description": "Custom system prompt for the summarization call. Uses a default if None."
          },
          "summary_provider": {
            "$ref": "#/components/schemas/ProviderConfig",
            "description": "Provider config for the summarization model (required — defined by control plane)."
          },
          "tail_messages": {
            "type": "integer",
            "format": "int32",
            "description": "Number of recent messages to preserve verbatim after compaction.",
            "minimum": 0
          },
          "token_budget": {
            "type": "integer",
            "format": "int32",
            "description": "Token budget. Compaction triggers when estimated tokens exceed this.",
            "minimum": 0
          }
        }
      },
      "ContentBlock": {
        "oneOf": [
          {
            "type": "object",
            "description": "Plain text content",
            "required": [
              "text",
              "type"
            ],
            "properties": {
              "text": {
                "type": "string",
                "description": "The text content"
              },
              "type": {
                "type": "string",
                "enum": [
                  "text"
                ]
              }
            }
          },
          {
            "allOf": [
              {
                "$ref": "#/components/schemas/ToolCall",
                "description": "A tool call request"
              },
              {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "tool_call"
                    ]
                  }
                }
              }
            ],
            "description": "A tool call request"
          },
          {
            "allOf": [
              {
                "$ref": "#/components/schemas/ToolResult",
                "description": "A tool execution result"
              },
              {
                "type": "object",
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": [
                      "tool_result"
                    ]
                  }
                }
              }
            ],
            "description": "A tool execution result"
          },
          {
            "type": "object",
            "description": "An image attachment",
            "required": [
              "media_type",
              "data",
              "type"
            ],
            "properties": {
              "data": {
                "type": "string",
                "description": "Base64-encoded image data"
              },
              "media_type": {
                "type": "string",
                "description": "MIME type of the image"
              },
              "type": {
                "type": "string",
                "enum": [
                  "image"
                ]
              }
            }
          }
        ],
        "description": "A content block within a message."
      },
      "ConversationRecord": {
        "type": "object",
        "description": "A conversation with its full message history, as returned by the control plane.",
        "required": [
          "id",
          "agent_id",
          "created_at",
          "updated_at",
          "messages"
        ],
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Agent that owns this conversation."
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the conversation was created."
          },
          "id": {
            "$ref": "#/components/schemas/String",
            "description": "Unique conversation identifier."
          },
          "messages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Message"
            },
            "description": "Full message history."
          },
          "title": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional human-readable title."
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "When the conversation was last updated."
          }
        }
      },
      "GlobalMetrics": {
        "type": "object",
        "description": "Global metrics across all agents.",
        "required": [
          "total_agents",
          "total_active_conversations",
          "uptime_secs"
        ],
        "properties": {
          "total_active_conversations": {
            "type": "integer",
            "format": "int64",
            "description": "Total active conversations across all agents",
            "minimum": 0
          },
          "total_agents": {
            "type": "integer",
            "description": "Total number of loaded agents",
            "minimum": 0
          },
          "uptime_secs": {
            "type": "integer",
            "format": "int64",
            "description": "Seconds since the runtime started",
            "minimum": 0
          }
        }
      },
      "HydrateConversationsRequest": {
        "type": "object",
        "required": [
          "conversations"
        ],
        "properties": {
          "conversations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ConversationRecord"
            }
          }
        }
      },
      "IntegrationAction": {
        "type": "object",
        "description": "A single action within an integration that an agent can invoke.\n\nEach action maps to a specific API operation on the external service.\nThe control plane defines the schema and permissions for each action.",
        "required": [
          "name",
          "description",
          "parameters_schema",
          "permission"
        ],
        "properties": {
          "description": {
            "type": "string",
            "description": "Human-readable description of what this action does."
          },
          "name": {
            "type": "string",
            "description": "Action identifier (e.g., \"create_pull_request\", \"send_message\")."
          },
          "parameters_schema": {
            "description": "JSON Schema for the action's parameters."
          },
          "permission": {
            "$ref": "#/components/schemas/ToolPermission",
            "description": "Permission level for this action."
          }
        }
      },
      "IntegrationDefinition": {
        "type": "object",
        "description": "Definition of an external integration available to an agent.\n\nEach integration represents a connection to an external service (e.g., GitHub,\nMailchimp, Slack) managed by the control plane. The control plane handles\nauthentication and proxies requests to the underlying service.",
        "required": [
          "name",
          "description",
          "actions"
        ],
        "properties": {
          "actions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IntegrationAction"
            },
            "description": "Available actions within this integration."
          },
          "description": {
            "type": "string",
            "description": "Human-readable description of the integration."
          },
          "name": {
            "type": "string",
            "description": "Integration identifier (e.g., \"github\", \"mailchimp\", \"slack\")."
          }
        }
      },
      "McpServerDefinition": {
        "type": "object",
        "description": "Definition of an MCP server that an agent connects to.",
        "required": [
          "name",
          "transport"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the MCP server"
          },
          "transport": {
            "$ref": "#/components/schemas/McpTransport",
            "description": "Transport configuration for connecting to the server"
          }
        }
      },
      "McpTransport": {
        "oneOf": [
          {
            "type": "object",
            "description": "Stdio transport — spawns a child process",
            "required": [
              "command",
              "type"
            ],
            "properties": {
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Command arguments"
              },
              "command": {
                "type": "string",
                "description": "Command to execute"
              },
              "env": {
                "type": "object",
                "description": "Environment variables for the process",
                "additionalProperties": {
                  "type": "string"
                },
                "propertyNames": {
                  "type": "string"
                }
              },
              "type": {
                "type": "string",
                "enum": [
                  "stdio"
                ]
              }
            }
          },
          {
            "type": "object",
            "description": "Streamable HTTP transport — connects to an HTTP endpoint",
            "required": [
              "url",
              "type"
            ],
            "properties": {
              "headers": {
                "type": "object",
                "description": "Additional HTTP headers",
                "additionalProperties": {
                  "type": "string"
                },
                "propertyNames": {
                  "type": "string"
                }
              },
              "type": {
                "type": "string",
                "enum": [
                  "streamable_http"
                ]
              },
              "url": {
                "type": "string",
                "description": "Server URL"
              }
            }
          }
        ],
        "description": "Transport configuration for MCP server connections."
      },
      "Message": {
        "type": "object",
        "description": "A message in a conversation.",
        "required": [
          "role",
          "content",
          "timestamp"
        ],
        "properties": {
          "content": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentBlock"
            },
            "description": "Content blocks of the message"
          },
          "role": {
            "$ref": "#/components/schemas/Role",
            "description": "Role of the message sender"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the message was created"
          }
        }
      },
      "MetricsResponse": {
        "type": "object",
        "description": "Complete metrics response for GET /metrics.",
        "required": [
          "timestamp",
          "agents",
          "global"
        ],
        "properties": {
          "agents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MetricsSnapshot"
            },
            "description": "Per-agent metrics"
          },
          "global": {
            "$ref": "#/components/schemas/GlobalMetrics",
            "description": "Global metrics"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of the snapshot"
          }
        }
      },
      "MetricsSnapshot": {
        "type": "object",
        "description": "Serializable snapshot of agent metrics for the /metrics endpoint.",
        "required": [
          "agent_id",
          "agent_name",
          "input_tokens",
          "output_tokens",
          "total_tokens",
          "total_requests",
          "failed_requests",
          "active_conversations",
          "total_conversations",
          "tool_calls",
          "avg_latency_ms"
        ],
        "properties": {
          "active_conversations": {
            "type": "integer",
            "format": "int64",
            "description": "Currently active conversations",
            "minimum": 0
          },
          "agent_id": {
            "$ref": "#/components/schemas/String",
            "description": "Agent identifier"
          },
          "agent_name": {
            "type": "string",
            "description": "Agent name"
          },
          "avg_latency_ms": {
            "type": "number",
            "format": "double",
            "description": "Average latency in milliseconds"
          },
          "failed_requests": {
            "type": "integer",
            "format": "int64",
            "description": "Failed requests",
            "minimum": 0
          },
          "input_tokens": {
            "type": "integer",
            "format": "int64",
            "description": "Total input tokens consumed",
            "minimum": 0
          },
          "output_tokens": {
            "type": "integer",
            "format": "int64",
            "description": "Total output tokens generated",
            "minimum": 0
          },
          "tool_calls": {
            "type": "integer",
            "format": "int64",
            "description": "Total tool calls executed",
            "minimum": 0
          },
          "total_conversations": {
            "type": "integer",
            "format": "int64",
            "description": "Total conversations ever created",
            "minimum": 0
          },
          "total_requests": {
            "type": "integer",
            "format": "int64",
            "description": "Total LLM requests",
            "minimum": 0
          },
          "total_tokens": {
            "type": "integer",
            "format": "int64",
            "description": "Total tokens (input + output)",
            "minimum": 0
          }
        }
      },
